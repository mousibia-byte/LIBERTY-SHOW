<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ════════════════════════════════════════════════════════════════
         1. صلاحيات الإنترنت والشبكة
         ════════════════════════════════════════════════════════════════ -->

    <!-- الوصول إلى الإنترنت (ضروري للبحث والتورنت) -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- مراقبة حالة الشبكة (واي فاي / بيانات) -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- مراقبة حالة الواي فاي تحديداً -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />

    <!-- تغيير إعدادات الواي فاي (اختياري - لبعض مكتبات التورنت) -->
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />

    <!-- الحصول على IP الكامل للجهاز عبر الواي فاي (مطلوب لـ DHT في التورنت) -->
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />


    <!-- ════════════════════════════════════════════════════════════════
         2. صلاحيات التخزين (الهاتف الداخلي)
         ════════════════════════════════════════════════════════════════ -->

    <!-- قراءة التخزين الخارجي - Android 9 وأقل -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- كتابة التخزين الخارجي - Android 9 وأقل -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29"
        tools:ignore="ScopedStorage" />

    <!-- إدارة كامل التخزين - Android 11+ (مطلوب للحفظ في أي مسار) -->
    <uses-permission
        android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />

    <!-- قراءة ملفات الوسائط - Android 13+ -->
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <!-- قراءة الملفات الأخرى (SRT, ASS ترجمات) - Android 13+ -->
    <!-- تغطي ملفات الترجمة التي ليست وسائط -->
    <uses-permission android:name="android.permission.READ_MEDIA_VISUAL_USER_SELECTED" />


    <!-- ════════════════════════════════════════════════════════════════
         3. صلاحيات USB والتخزين الخارجي
         ════════════════════════════════════════════════════════════════ -->

    <!-- الوصول إلى أجهزة USB (للحفظ على USB) -->
    <uses-permission android:name="android.permission.USB_PERMISSION"
        tools:ignore="SystemPermission" />

    <!-- المطلوب للـ SAF (Storage Access Framework) لاختيار مجلد USB -->
    <!-- يُمنح عبر Intent.FLAG_GRANT_PERSISTABLE_URI_PERMISSION تلقائياً -->


    <!-- ════════════════════════════════════════════════════════════════
         4. صلاحيات الخدمة الأمامية (Foreground Service)
         ════════════════════════════════════════════════════════════════ -->

    <!-- تشغيل خدمة التورنت في الخلفية مع إشعار -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <!-- نوع الخدمة: تنزيل بيانات - Android 14+ -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- منع الجهاز من النوم أثناء التحميل -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- تشغيل التطبيق عند بدء الجهاز (لاستكمال التنزيلات) -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />


    <!-- ════════════════════════════════════════════════════════════════
         5. صلاحيات الإشعارات
         ════════════════════════════════════════════════════════════════ -->

    <!-- إرسال الإشعارات - Android 13+ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- تحديث الإشعار المستمر أثناء التنزيل -->
    <uses-permission android:name="android.permission.UPDATE_DEVICE_STATS"
        tools:ignore="ProtectedPermissions" />


    <!-- ════════════════════════════════════════════════════════════════
         6. صلاحيات الأداء والبطارية
         ════════════════════════════════════════════════════════════════ -->

    <!-- طلب استثناء من توفير البطارية (لاستمرار التنزيل) -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- منع وضع Doze من إيقاف التنزيل -->
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />


    <!-- ════════════════════════════════════════════════════════════════
         7. صلاحيات تشغيل الفيديو
         ════════════════════════════════════════════════════════════════ -->

    <!-- التحكم في مستوى الصوت -->
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />

    <!-- تشغيل الفيديو على تلفزيون / شاشة خارجية -->
    <uses-permission android:name="android.permission.BLUETOOTH" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT"
        android:minSdkVersion="31" />


    <!-- ════════════════════════════════════════════════════════════════
         8. صلاحيات خاصة بالتلفزيون (Android TV)
         ════════════════════════════════════════════════════════════════ -->

    <!-- دعم leanback لـ Android TV -->
    <uses-feature
        android:name="android.software.leanback"
        android:required="false" />

    <!-- الشاشة التلمسية غير مطلوبة (TV) -->
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />


    <!-- ════════════════════════════════════════════════════════════════
         تعريف التطبيق
         ════════════════════════════════════════════════════════════════ -->

    <application
        android:name=".App"
        android:allowBackup="true"
        android:icon="@android:drawable/sym_def_app_icon"
        android:label="@string/app_name"
        android:roundIcon="@android:drawable/sym_def_app_icon"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.NoActionBar"
        android:usesCleartextTraffic="true"
        android:requestLegacyExternalStorage="true"
        tools:targetApi="31">

        <!-- MainActivity -->
        <activity
            android:name=".MainActivity"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:exported="true"
            android:launchMode="singleTop"
            android:screenOrientation="landscape">

            <!-- تشغيل عادي -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <!-- TV Launcher -->
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>

            <!-- فتح روابط المغنت مباشرة من المتصفح -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="magnet" />
            </intent-filter>

            <!-- فتح ملفات .torrent -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/x-bittorrent" />
            </intent-filter>

        </activity>

        <!-- خدمة التورنت الأمامية -->
        <service
            android:name=".TorrentService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- FileProvider لمشاركة الملفات مع المشغل الخارجي -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- استكمال التنزيلات عند إعادة تشغيل الجهاز -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>